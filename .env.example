# Connection string do Neon (PostgreSQL)
NEON_API_KEY=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Autenticação (mín. 16 caracteres)
AUTH_JWT_SECRET=change-me-to-a-long-random-secret

# URL do frontend (OAuth redirect após login Google)
FRONTEND_URL=http://localhost:5173

# Google OAuth (opcional — habilita botão "Entrar com Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev (via proxy Vite): http://localhost:5173/api/auth/google/callback
# Prod: https://SEU-DOMINIO.netlify.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# Desenvolvimento local: npm run dev sobe API (porta 3001) + Vite (proxy /api)
# Opcional: porta customizada da API local
# API_PORT=3001

# Cron para limpar salas temporárias expiradas
# CRON_SECRET=
